-keep @interface org.monyhar.weblayer.VerifiesOnO
-if @org.monyhar.weblayer.VerifiesOnO class * {
    *** *(...);
}
-keep,allowobfuscation class <1> {
    *** <2>(...);
}
-keepclassmembers,allowobfuscation class ** {
  @org.monyhar.weblayer.VerifiesOnO <methods>;
}

-keep @interface org.monyhar.weblayer.VerifiesOnR
-if @org.monyhar.weblayer.VerifiesOnR class * {
    *** *(...);
}
-keep,allowobfuscation class <1> {
    *** <2>(...);
}
-keepclassmembers,allowobfuscation class ** {
  @org.monyhar.weblayer.VerifiesOnR <methods>;
}

# Android uses reflection to create an instance of this.
-keep class org.monyhar.weblayer.BrowserFragment$BrowserViewModel
